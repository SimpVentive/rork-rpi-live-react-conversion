{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",

    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["node"],   // ✅ FIX

    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "esModuleInterop": true
  }
}